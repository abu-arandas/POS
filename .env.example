# Supabase credentials used by the seed script (scripts/seed.mjs).
# Create a project at https://supabase.com, then copy its Project URL and the
# anon/public API key from Project Settings → API.
#
# Copy this file to .env and fill in your own values. Never commit real keys.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
