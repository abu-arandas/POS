# Supabase credentials used by the seed script (scripts/seed.mjs).
# Create a project at https://supabase.com, then copy its Project URL and keys
# from Project Settings → API.
#
# Copy this file to .env and fill in your own values. Never commit real keys.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# Preferred for seeding: the service_role key bypasses Row Level Security
# (which the default schema enables). SERVER-SIDE ONLY — never ship it in the
# app or expose it to a browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Fallback: the public anon key. Seeding with it only works if you disabled
# RLS (throwaway demos only).
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
